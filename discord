	end)
	return ok and t or { Visible=false, Text="", Position=Vector2.zero, Color=Color3.new(1,1,1), Size=13, Center=true, Outline=true, Transparency=1, Remove=function() end }
end

local function CreateESPForPlayer(plr)
	if ESPObjects[plr] then return end
	local Box = NewSquare()
	local Fill = NewSquare(); Fill.Filled=true; Fill.Thickness=0
	local TLH,TLV = NewLine(),NewLine()
	local TRH,TRV = NewLine(),NewLine()
	local BLH,BLV = NewLine(),NewLine()
	local BRH,BRV = NewLine(),NewLine()
	local NameText = NewText(); NameText.Size=13
	local DistText = NewText(); DistText.Size=11; DistText.Color=Color3.fromRGB(200,200,200)
	local HealthBg = NewSquare(); HealthBg.Filled=true; HealthBg.Thickness=0; HealthBg.Color=Color3.fromRGB(20,20,20)
	local HealthBar = NewSquare(); HealthBar.Filled=true; HealthBar.Thickness=0
	ESPObjects[plr] = { Box=Box,Fill=Fill,TLH=TLH,TLV=TLV,TRH=TRH,TRV=TRV,BLH=BLH,BLV=BLV,BRH=BRH,BRV=BRV,NameText=NameText,DistText=DistText,HealthBg=HealthBg,HealthBar=HealthBar }
end

local function RemoveESPForPlayer(plr)
	if not ESPObjects[plr] then return end
	for _, d in pairs(ESPObjects[plr]) do pcall(function() d:Remove() end) end
	ESPObjects[plr] = nil
end

local function HideESPForPlayer(plr)
	local o = ESPObjects[plr]; if not o then return end
	for _, d in pairs(o) do d.Visible = false end
end

local function GetESPColor(plr)
	return ESPTargets[plr.UserId] and Color3.fromRGB(255,50,50) or ESPWhitelist[plr.UserId] and Color3.fromRGB(50,255,100) or Color3.fromRGB(150,60,255)
end

local function GetCharBounds(char)
	local hrp = char:FindFirstChild("HumanoidRootPart"); if not hrp then return nil end
	local pos = hrp.Position
	local topSc, tVis = Camera:WorldToViewportPoint(pos + Vector3.new(0,2.8,0))
	local botSc = Camera:WorldToViewportPoint(pos - Vector3.new(0,3.2,0))
	if not tVis or topSc.Z < 0 then return nil end
	local h = botSc.Y - topSc.Y; if h <= 2 then return nil end
	local w = h * 0.65
	return { X=topSc.X-w/2, Y=topSc.Y, W=w, H=h, MidX=topSc.X }
end

