task.spawn(function()
	local PromptCache = {}
	local con1, con2
	local function AddPrompt(p) PromptCache[p] = true end
	local function RemPrompt(p) PromptCache[p] = nil end

	local PPS = game:GetService("ProximityPromptService")
	con1 = PPS.PromptShown:Connect(AddPrompt)
	con2 = PPS.PromptHidden:Connect(RemPrompt)

	for _, v in ipairs(workspace:GetDescendants()) do if v:IsA("ProximityPrompt") then AddPrompt(v) end end

	while true do
		if not ScreenGui or not ScreenGui.Parent then
			if con1 then con1:Disconnect() end
			if con2 then con2:Disconnect() end
			break
		end
		if State.Toggles["Auto Lockpick"] then
			local char = LocalPlayer.Character
			local hrp  = char and char:FindFirstChild("HumanoidRootPart")
			if hrp then
				for prompt in pairs(PromptCache) do
					if prompt.Parent and prompt.Enabled then
						local txt = prompt.ActionText:lower()
						if txt:find("pick") or txt:find("crack") or txt:find("safe") or txt:find("register") then
							local part = prompt.Parent
							if part:IsA("BasePart") and (part.Position - hrp.Position).Magnitude <= prompt.MaxActivationDistance * 1.2 then
								pcall(function() fireproximityprompt(prompt) end)
							end
						end
					end
				end
			end
		end
		task.wait(0.2)
	end
end)

