Create("UIPadding", { PaddingTop=UDim.new(0,4), PaddingLeft=UDim.new(0,6), PaddingRight=UDim.new(0,6), Parent=kbScroll })

local kbSnapshot = {}

RefreshKeybinds = function()
	for _, c in ipairs(kbScroll:GetChildren()) do
		if c:IsA("Frame") then c:Destroy() end
	end

	local active = {}
	for label, bind in pairs(KeyBinds) do
		if bind.key then table.insert(active, { label=label, key=bind.key }) end
	end
	table.sort(active, function(a, b) return a.label < b.label end)

	if #active == 0 then
		kbEmpty.Visible=true; kbScroll.Visible=false
		kbWin.Size=UDim2.new(0,220,0,60); return
	end

	kbEmpty.Visible=false; kbScroll.Visible=true

	for _, entry in ipairs(active) do
		local row=Create("Frame",{
			Size=UDim2.new(1,0,0,20),
			BackgroundColor3=Color3.fromRGB(0,0,0),
			BorderSizePixel=0, ZIndex=53, Parent=kbScroll,
		})
		Create("UICorner",{CornerRadius=UDim.new(0,4),Parent=row})
		Create("UIStroke",{Color=Color3.fromRGB(50,0,80),Thickness=1,Parent=row})
		Create("TextLabel",{Text=entry.label, Font=Enum.Font.GothamSemibold, TextSize=11, TextColor3=CONFIG.TextColor, BackgroundTransparency=1, Position=UDim2.new(0,8,0,0), Size=UDim2.new(1,-56,1,0), TextXAlignment=Enum.TextXAlignment.Left, ZIndex=54, Parent=row})
		local keyBadge=Create("TextLabel",{
			Text=KeyCodeName(entry.key), Font=Enum.Font.GothamBold, TextSize=10,
			TextColor3=CONFIG.AccentColor,
			BackgroundColor3=Color3.fromRGB(10,0,18),
			Position=UDim2.new(1,-50,0.5,-9), Size=UDim2.new(0,46,0,18),
			TextXAlignment=Enum.TextXAlignment.Center, ZIndex=54, Parent=row,
		})
		Create("UICorner",{CornerRadius=UDim.new(0,3),Parent=keyBadge})
		Create("UIStroke",{Color=CONFIG.AccentColor,Thickness=1,Parent=keyBadge})
	end

	local h=math.min(34+8+#active*22+8,300)
	kbWin.Size=UDim2.new(0,220,0,h)
end

local function KeyBindsChanged()
	for label,bind in pairs(KeyBinds) do
		if kbSnapshot[label]~=bind.key then return true end
	end
	for label in pairs(kbSnapshot) do
		if not KeyBinds[label] or not KeyBinds[label].key then return true end
	end
	return false
end

local function SnapKeybinds()
	kbSnapshot={}
	for label,bind in pairs(KeyBinds) do kbSnapshot[label]=bind.key end
end

Connections[#Connections+1] = RunService.Heartbeat:Connect(function()
	if not kbWin.Visible then return end
	if KeyBindsChanged() then SnapKeybinds(); RefreshKeybinds() end
end)

