local ExtraESPObjects = {}
local ExtraESPItems   = {}

local function GetExtraItemInfo(obj, ignoreToggles)
	local n = obj.Name:lower()
	if (n:find("cashdrop1") or n:find("cashdrop2") or n:find("cashdrop3")) then
		if ignoreToggles or State.Toggles["CashDrop ESP"] then return "Cash", Color3.fromRGB(100, 255, 100) end
	elseif (n == "s1" or n == "s2") and obj.Parent and obj.Parent.Name == "SpawnedPiles" then
		if ignoreToggles or State.Toggles["Piles & Gift ESP"] then return "Scrap", Color3.fromRGB(200, 200, 200) end
	elseif (n:find("armoryman") or n:find("dealerman")) then
	elseif obj.Parent and (obj.Parent.Name:lower() == "dealer" or obj.Parent.Name:lower() == "armorydealer") then
		if ignoreToggles or State.Toggles["Dealer ESP"] then return "Dealer", Color3.fromRGB(255, 50, 50) end
	elseif (n:find("crate") or n:find("box")) then
		if ignoreToggles or State.Toggles["Crates ESP"] then return "Crate", Color3.fromRGB(160, 110, 60) end
	end
	return nil, nil
end

local function RegisterExtraItem(v)
	if not v then return end
	if v:IsA("Model") or v:IsA("BasePart") then
		if GetExtraItemInfo(v, true) then
			table.insert(ExtraESPItems, v)
		end
	end
end

task.spawn(function()
	task.wait(1)
	for _, v in ipairs(workspace:GetDescendants()) do
		RegisterExtraItem(v)
	end
	Connections[#Connections+1] = workspace.DescendantAdded:Connect(RegisterExtraItem)
end)

Connections[#Connections+1] = RunService.RenderStepped:Connect(function()
	local myPos   = Camera.CFrame.Position
	local maxDist = State.Sliders["ESP Distance"] or 1000

	for _, item in ipairs(ExtraESPItems) do
		local label, color = GetExtraItemInfo(item)
		if label and item.Parent then
			local pos
			if item:IsA("Model") then
				local pp = item.PrimaryPart or item:FindFirstChild("HumanoidRootPart") or item:FindFirstChild("Head") or item:FindFirstChildWhichIsA("BasePart")
				if pp then pos = pp.Position end
			elseif item:IsA("BasePart") then
				pos = item.Position
			elseif item:IsA("Tool") then
				local h = item:FindFirstChild("Handle")
				if h then pos = h.Position end
			end

			if pos then
				local dist = (myPos - pos).Magnitude
				if dist <= maxDist then
					local sPos, vis = Camera:WorldToViewportPoint(pos)
					if vis then
						if not ExtraESPObjects[item] then
							ExtraESPObjects[item] = NewText()
							ExtraESPObjects[item].Center = true
							ExtraESPObjects[item].Outline = true
						end
						local t = ExtraESPObjects[item]
						t.Visible  = true
						t.Text     = label .. string.format(" [%d]", dist)
						t.Color    = color
						t.Position = Vector2.new(sPos.X, sPos.Y)
						t.Size     = State.Sliders["ESP Text Size"] or 13
						continue
					end
				end
			else
				if ExtraESPObjects[item] then ExtraESPObjects[item].Visible = false end
			end
		end
		if ExtraESPObjects[item] then ExtraESPObjects[item].Visible = false end
	end

	for item, obj in pairs(ExtraESPObjects) do
		if not item.Parent then
			obj:Remove()
			ExtraESPObjects[item] = nil
		end
	end
end)

