local function GetPartPosition(char, partName)
	if partName == "Head" then
		local h = char:FindFirstChild("Head")
		return h and h.Position
	elseif partName == "Torso" then
		local t = char:FindFirstChild("UpperTorso") or char:FindFirstChild("Torso")
		return t and t.Position
	elseif partName == "Limbs" then
		local limbs = {"RightLowerArm","LeftLowerArm","RightLowerLeg","LeftLowerLeg"}
		for _, n in ipairs(limbs) do
			local p = char:FindFirstChild(n)
			if p then return p.Position end
		end
	end
	local hrp = char:FindFirstChild("HumanoidRootPart")
	return hrp and hrp.Position
end

local function IsVisible(pos)
	local origin    = Camera.CFrame.Position
	local direction = (pos - origin)
	local ray       = RaycastParams.new()
	ray.FilterType  = Enum.RaycastFilterType.Exclude
	ray.FilterDescendantsInstances = { LocalPlayer.Character or workspace }
	local result = workspace:Raycast(origin, direction, ray)
	if not result then return true end
	local hit = result.Instance
	for _, plr in ipairs(Players:GetPlayers()) do
		if plr.Character and hit:IsDescendantOf(plr.Character) then
			return true
		end
	end
	return false
end

local function GetLocalTeam()
	return LocalPlayer.Team
end

local function IsSameTeam(plr)
	local myTeam = GetLocalTeam()
	if not myTeam then return false end
	return plr.Team == myTeam
end

local function GetAimbotTarget()
	local center   = Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y / 2)
	local fov      = AimbotConfig.FOVSize
	local best     = nil
	local bestDist = math.huge

	for _, plr in ipairs(Players:GetPlayers()) do
		if plr == LocalPlayer then continue end
		local char = plr.Character
		local hum  = char and char:FindFirstChildOfClass("Humanoid")
		if not char or not hum or hum.Health <= 0 then continue end

		if AimbotConfig.CheckWhitelist and ESPWhitelist[plr.UserId] then continue end
		if AimbotConfig.CheckTeam and IsSameTeam(plr) then continue end

		local partPos = GetPartPosition(char, AimbotConfig.TargetPart)
		if not partPos then continue end

		local hrp = char:FindFirstChild("HumanoidRootPart")
		if AimbotConfig.UseVelocity and hrp then
			local vel   = hrp.AssemblyLinearVelocity
			local dist3 = (Camera.CFrame.Position - partPos).Magnitude
			local tof   = dist3 / 300
			partPos     = partPos + vel * tof
		end

		local screenPos, onScreen = Camera:WorldToViewportPoint(partPos)
		if not onScreen or screenPos.Z < 0 then continue end

		local sp2      = Vector2.new(screenPos.X, screenPos.Y)
		local d2screen = (sp2 - center).Magnitude
		if d2screen > fov then continue end

		if AimbotConfig.CheckWalls and not IsVisible(partPos) then continue end

		if d2screen < bestDist then
			bestDist = d2screen
			best     = { plr = plr, screenPos = sp2, worldPos = partPos }
		end
	end

	return best
end

