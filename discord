local MeleeConfig = {
	Enabled        = false,
	Animation      = false,
	CheckDowned    = false,
	CheckWhitelist = false,
	CheckTeam      = false,
	Distance       = 1,
	HitPart        = "Head",
}

local function GetMeleeTarget()
	local char = LocalPlayer.Character
	local hrp  = char and char:FindFirstChild("HumanoidRootPart")
	if not hrp then return nil end

	local best, bestDist = nil, math.huge
	for _, plr in ipairs(Players:GetPlayers()) do
		if plr == LocalPlayer then continue end
		local c    = plr.Character
		local hum  = c and c:FindFirstChildOfClass("Humanoid")
		local pHRP = c and c:FindFirstChild("HumanoidRootPart")
		if not c or not hum or not pHRP then continue end

		if MeleeConfig.CheckDowned then
			if hum.Health <= 0 then continue end
			local downed = c:FindFirstChild("Downed") or c:FindFirstChild("KnockedDown")
			if downed and downed.Value then continue end
		end

		if MeleeConfig.CheckWhitelist and ESPWhitelist[plr.UserId] then continue end
		if MeleeConfig.CheckTeam     and IsSameTeam(plr) then continue end

		local dist = (hrp.Position - pHRP.Position).Magnitude
		if dist <= MeleeConfig.Distance and dist < bestDist then
			bestDist = dist
			best     = { plr = plr, char = c, hum = hum }
		end
	end
	return best
end

local function DoMeleeHit(target)
	local char = LocalPlayer.Character
	local tool = GetEquippedTool()
	if not tool then return end

	if MeleeConfig.Animation then
		tool:Activate()
	else
		local hitPart = target.char:FindFirstChild(MeleeConfig.HitPart) or target.char:FindFirstChild("Head")
		local handle  = tool:FindFirstChild("Handle")
		if handle and hitPart and firetouchinterest then
			firetouchinterest(handle, hitPart, 0)
			firetouchinterest(handle, hitPart, 1)
			return
		end

		local re = game:GetService("ReplicatedStorage"):FindFirstChild("HitEvent")
			or game:GetService("ReplicatedStorage"):FindFirstChild("MeleeHit")
			or game:GetService("ReplicatedStorage"):FindFirstChild("Hit")
		if re and re:IsA("RemoteEvent") then
			pcall(function() re:FireServer(hitPart, Vector3.zero) end)
		else
			local ev = tool:FindFirstChildWhichIsA("RemoteEvent", true)
			if ev then pcall(function() ev:FireServer(hitPart) end) end
		end
	end
end

local meleeAuraTick = 0
Connections[#Connections+1] = RunService.Heartbeat:Connect(function(dt)
