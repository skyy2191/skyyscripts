local function SetInfiniteStamina(v)
	InfStaminaEnabled = v
	if infStaminaConn then infStaminaConn:Disconnect(); infStaminaConn = nil end
	if infStaminaRespawn then infStaminaRespawn:Disconnect(); infStaminaRespawn = nil end
	if not v then return end

	local StaminaTable = nil

	local function HookStamina()
		if getrenv and debug.getupvalue then
			task.spawn(function()
				task.wait(1)
				pcall(function()
					local _G = getrenv()._G
					local S_Take = _G.S_Take
					if not S_Take then return end
					local value = debug.getupvalue(S_Take, 2)
					for _, a in pairs(debug.getupvalues(value)) do
						if type(a) == "function" and debug.getinfo(a).name == "Upt_S" then
							local u7 = debug.getupvalue(value, 7)
							if type(u7) == "table" and rawget(u7, "S") then
								StaminaTable = u7
							end
							break
						end
					end
				end)
			end)
		end
	end

	HookStamina()
	infStaminaRespawn = LocalPlayer.CharacterAdded:Connect(HookStamina)

	infStaminaConn = RunService.RenderStepped:Connect(function()
		if InfStaminaEnabled and StaminaTable then
			StaminaTable.S = 100
		end

		local char = LocalPlayer.Character
		if not char then return end

		if char:GetAttribute("Stamina") ~= nil then
			local max = char:GetAttribute("MaxStamina") or 100
			char:SetAttribute("Stamina", max)
		end

		local st = char:FindFirstChild("Stamina", true) or char:FindFirstChild("Energy", true)
		if st and (st:IsA("NumberValue") or st:IsA("IntValue")) then
			st.Value = 100
		end
	end)
end

