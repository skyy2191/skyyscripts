local gcCache = {}
local origVals = {}
local toolMods = {}
local toolConns = {}
local recoilCharConn, recoilInvConn, recoilRespawnConn
local patched = {}
local noRecoilEnabled = false

local function scanMods()
	task.defer(function()
		for _, v in ipairs(getgc(true)) do
			if type(v) == 'table' and not gcCache[v] and rawget(v, 'Recoil') and rawget(v, 'EquipTime') and v.Name then
				gcCache[v] = true
				origVals[v] = {v.Recoil, v.AngleX_Min, v.AngleX_Max, v.AngleY_Min, v.AngleY_Max, v.AngleZ_Min, v.AngleZ_Max, v.EquipTime}
				if noRecoilEnabled and not patched[v] then
					v.Recoil, v.AngleX_Min, v.AngleX_Max, v.AngleY_Min, v.AngleY_Max, v.AngleZ_Min, v.AngleZ_Max = 0,0,0,0,0,0,0
					patched[v] = true
				end
			end
		end
	end)
end

local function applyMod(mod, enable)
	local o = origVals[mod]
	if not o then return end
	if enable then
		if patched[mod] then return end
		mod.Recoil, mod.AngleX_Min, mod.AngleX_Max, mod.AngleY_Min, mod.AngleY_Max, mod.AngleZ_Min, mod.AngleZ_Max = 0,0,0,0,0,0,0
		patched[mod] = true
	else
		mod.Recoil, mod.AngleX_Min, mod.AngleX_Max, mod.AngleY_Min, mod.AngleY_Max, mod.AngleZ_Min, mod.AngleZ_Max, mod.EquipTime = o[1],o[2],o[3],o[4],o[5],o[6],o[7],o[8]
		patched[mod] = nil
	end
end

local function applyAllRecoil(enable)
	for mod in pairs(gcCache) do applyMod(mod, enable) end
	for _, mod in pairs(toolMods) do applyMod(mod, enable) end
end

local function cleanupRecoil()
	if recoilCharConn then recoilCharConn:Disconnect(); recoilCharConn = nil end
	if recoilInvConn then recoilInvConn:Disconnect(); recoilInvConn = nil end
	for _, conns in pairs(toolConns) do for _, c in ipairs(conns) do c:Disconnect() end end
	table.clear(toolConns); table.clear(toolMods); table.clear(patched)
end

local function bindTool(tool)
	if toolMods[tool] then return end
	scanMods()
	task.defer(function()
		for mod in pairs(gcCache) do
			if mod.Name == tool.Name then
				toolMods[tool] = mod
				toolConns[tool] = {
					tool.Equipped:Connect(function() if noRecoilEnabled then applyMod(mod, true) end end),
					tool.Unequipped:Connect(function() if not noRecoilEnabled then applyMod(mod, false) end end)
				}
				if tool.Parent == LocalPlayer.Character and noRecoilEnabled then applyMod(mod, true) end
				break
			end
		end
	end)
end

local function setupRecoilListeners()
	local c = LocalPlayer.Character
	if not c then return end
	for _, t in ipairs(c:GetChildren()) do
		if t:IsA("Tool") and t:FindFirstChild("IsGun") then bindTool(t) end
	end
	if recoilCharConn then recoilCharConn:Disconnect() end
	recoilCharConn = c.ChildAdded:Connect(function(t)
		if t:IsA("Tool") and t:FindFirstChild("IsGun") then task.defer(bindTool, t) end
	end)
	if recoilInvConn then recoilInvConn:Disconnect() end
	recoilInvConn = LocalPlayer:WaitForChild("Backpack").ChildAdded:Connect(function(t)
		if t:IsA("Tool") and t:FindFirstChild("IsGun") then task.defer(bindTool, t) end
	end)
end

local function SetNoRecoil(v)
	if v == noRecoilEnabled then return end
	noRecoilEnabled = v

	if v then
		cleanupRecoil()
		scanMods()
		setupRecoilListeners()
		applyAllRecoil(true)

		if recoilRespawnConn then recoilRespawnConn:Disconnect() end
		recoilRespawnConn = LocalPlayer.CharacterAdded:Connect(function()
			if not noRecoilEnabled then return end
			task.defer(function() cleanupRecoil(); scanMods(); setupRecoilListeners(); applyAllRecoil(true) end)
		end)
	else
		applyAllRecoil(false)
		cleanupRecoil()
		if recoilRespawnConn then recoilRespawnConn:Disconnect(); recoilRespawnConn = nil end
	end
end

local instantReloadConn    = nil
local instantReloadEnabled = false

local function SetInstantReload(v)
	instantReloadEnabled = v
	if instantReloadConn then instantReloadConn:Disconnect(); instantReloadConn = nil end
	if not v then
		local char = LocalPlayer.Character
		if char then
			local hum = char:FindFirstChildOfClass("Humanoid")
			if hum and hum.GetPlayingAnimationTracks then
				for _, track in ipairs(hum:GetPlayingAnimationTracks()) do
					track.Speed = 1
				end
			end
		end
		return
	end

	instantReloadConn = RunService.Heartbeat:Connect(function()
		if not instantReloadEnabled then return end
		if not IsRangedEquipped() then return end
		local char = LocalPlayer.Character
		if not char then return end
		local hum = char:FindFirstChildOfClass("Humanoid")
		if not hum then return end
		for _, track in ipairs(hum:GetPlayingAnimationTracks()) do
			local n = track.Name:lower()
			if n:find("reload") or n:find("load") then
				if track.Speed < 10 then
					track:AdjustSpeed(100)
				end
			end
		end
	end)
end

