local function MakeToggle(parent, label, default, bindable, callback)
	local enabled = default or false
	State.Toggles[label] = enabled

	local row = Create("Frame", {
		Size=UDim2.new(1,-10,0,30),
		BackgroundColor3=Color3.fromRGB(0, 0, 0),
		BackgroundTransparency=0,
		BorderSizePixel=0,
		Parent=parent,
	})
	Create("UICorner", { CornerRadius=UDim.new(0,5), Parent=row })
	Create("UIStroke", { Color=Color3.fromRGB(60, 0, 100), Thickness=1, Parent=row })

	local switch = Create("Frame", {
		Size=UDim2.new(0,32,0,16),
		Position=UDim2.new(0,6,0.5,-8),
		BackgroundColor3=enabled and CONFIG.AccentColor or Color3.fromRGB(20, 0, 35),
		BorderSizePixel=0,
		Parent=row,
	})
	Create("UICorner", { CornerRadius=UDim.new(1,0), Parent=switch })

	local knob = Create("Frame", {
		Size=UDim2.new(0,12,0,12),
		Position=UDim2.new(0,enabled and 18 or 2,0.5,-6),
		BackgroundColor3=enabled and Color3.fromRGB(255,255,255) or Color3.fromRGB(130,80,200),
		BorderSizePixel=0,
		Parent=switch,
	})
	Create("UICorner", { CornerRadius=UDim.new(1,0), Parent=knob })

	local function DoToggle()
		enabled = not enabled; State.Toggles[label] = enabled
		Tween(switch, { BackgroundColor3=enabled and CONFIG.AccentColor or Color3.fromRGB(20, 0, 35) }, 0.2)
		Tween(knob, {
			Position=UDim2.new(0,enabled and 18 or 2,0.5,-6),
			BackgroundColor3=enabled and Color3.fromRGB(255,255,255) or Color3.fromRGB(130,80,200),
		}, 0.2)
		local stroke = row:FindFirstChildOfClass("UIStroke")
		if stroke then
			Tween(stroke, { Color=enabled and Color3.fromRGB(150,0,255) or Color3.fromRGB(60,0,100) }, 0.2)
		end
		if callback then callback(enabled) end
	end

	if bindable then
		Create("TextLabel", {
			Text=label, Font=Enum.Font.GothamMedium, TextSize=13,
			TextColor3=CONFIG.TextColor, BackgroundTransparency=1,
			Position=UDim2.new(0,46,0,0), Size=UDim2.new(1,-100,1,0),
			TextXAlignment=Enum.TextXAlignment.Left, Parent=row,
		})

		local kbBtn = Create("TextButton", {
			Text="NONE", Font=Enum.Font.GothamBold, TextSize=10,
			TextColor3=CONFIG.AccentColor,
			BackgroundColor3=Color3.fromRGB(15, 0, 25),
			Position=UDim2.new(1,-54,0.5,-11), Size=UDim2.new(0,48,0,22),
			TextXAlignment=Enum.TextXAlignment.Center, Parent=row,
		})
		Create("UICorner", { CornerRadius=UDim.new(0,4), Parent=kbBtn })
		Create("UIStroke", { Color=Color3.fromRGB(100, 0, 180), Thickness=1, Parent=kbBtn })

		KeyBinds[label] = { key=nil, fire=DoToggle }

		local listening = false
		kbBtn.MouseButton1Click:Connect(function()
			if listening then return end
			listening = true
			kbBtn.Text = "..."
			kbBtn.TextColor3 = Color3.fromRGB(200, 100, 255)
			local conn
			conn = UserInputService.InputBegan:Connect(function(input)
				if input.UserInputType == Enum.UserInputType.Keyboard then
					local kc = input.KeyCode
					if kc == Enum.KeyCode.Escape or kc == Enum.KeyCode.Delete or kc == Enum.KeyCode.Backspace then
						KeyBinds[label].key = nil
						kbBtn.Text = "NONE"
						kbBtn.TextColor3 = CONFIG.AccentColor
					else
						KeyBinds[label].key = kc
						kbBtn.Text = KeyCodeName(kc)
						kbBtn.TextColor3 = CONFIG.AccentColor
					end
					listening = false
					conn:Disconnect()
				end
			end)
		end)

		kbBtn.MouseButton2Click:Connect(function()
			if listening then return end
			KeyBinds[label].key = nil
			kbBtn.Text = "NONE"
			kbBtn.TextColor3 = CONFIG.AccentColor
		end)

		local btn = Create("TextButton", { Text="", BackgroundTransparency=1, Size=UDim2.new(1,-56,1,0), Parent=row })
		btn.MouseButton1Click:Connect(function() if not listening then DoToggle() end end)
	else
		Create("TextLabel", {
			Text=label, Font=Enum.Font.GothamMedium, TextSize=13,
			TextColor3=CONFIG.TextColor, BackgroundTransparency=1,
			Position=UDim2.new(0,46,0,0), Size=UDim2.new(1,-46,1,0),
			TextXAlignment=Enum.TextXAlignment.Left, Parent=row,
		})
		local btn = Create("TextButton", { Text="", BackgroundTransparency=1, Size=UDim2.new(1,0,1,0), Parent=row })
		btn.MouseButton1Click:Connect(DoToggle)
	end

	local btn2 = row:FindFirstChildOfClass("TextButton")
	if btn2 then
		btn2.MouseEnter:Connect(function()
			Tween(row, { BackgroundColor3=Color3.fromRGB(8, 0, 15) }, 0.1)
		end)
		btn2.MouseLeave:Connect(function()
			Tween(row, { BackgroundColor3=Color3.fromRGB(0, 0, 0) }, 0.1)
		end)
	end

	return row
end

local function MakeSlider(parent, label, min, max, default, callback)
	local val = default or min; State.Sliders[label] = val
	local c = Create("Frame", {
		Size=UDim2.new(1,-10,0,48),
		BackgroundColor3=Color3.fromRGB(0, 0, 0),
		BackgroundTransparency=0,
		BorderSizePixel=0,
		Parent=parent,
	})
	Create("UICorner", { CornerRadius=UDim.new(0,5), Parent=c })
	Create("UIStroke", { Color=Color3.fromRGB(60, 0, 100), Thickness=1, Parent=c })
	Create("UIPadding", { PaddingLeft=UDim.new(0,8), PaddingRight=UDim.new(0,8), Parent=c })

	local hdr = Create("Frame", { Size=UDim2.new(1,0,0,22), BackgroundTransparency=1, Parent=c })
	Create("TextLabel", {
		Text=label, Font=Enum.Font.GothamMedium, TextSize=12,
		TextColor3=CONFIG.TextColor, BackgroundTransparency=1,
		Position=UDim2.new(0,0,0,0), Size=UDim2.new(0.7,0,1,0),
		TextXAlignment=Enum.TextXAlignment.Left, Parent=hdr,
	})
	local vLbl = Create("TextLabel", {
		Text=tostring(val), Font=Enum.Font.GothamBold, TextSize=12,
		TextColor3=CONFIG.AccentColor, BackgroundTransparency=1,
		Position=UDim2.new(0.7,0,0,0), Size=UDim2.new(0.3,0,1,0),
		TextXAlignment=Enum.TextXAlignment.Right, Parent=hdr,
	})
	local track = Create("Frame", {
		Size=UDim2.new(1,0,0,4), Position=UDim2.new(0,0,0,28),
		BackgroundColor3=Color3.fromRGB(30, 0, 50),
		BorderSizePixel=0, Parent=c,
	})
	Create("UICorner", { CornerRadius=UDim.new(1,0), Parent=track })
	local pct = (val-min)/(max-min)
	local fill = Create("Frame", {
		Size=UDim2.new(pct,0,1,0),
		BackgroundColor3=CONFIG.AccentColor,
		BorderSizePixel=0, Parent=track,
	})
	Create("UICorner", { CornerRadius=UDim.new(1,0), Parent=fill })
	local knob = Create("Frame", {
		Size=UDim2.new(0,12,0,12),
		Position=UDim2.new(pct,-6,0.5,-6),
		BackgroundColor3=Color3.fromRGB(200, 100, 255),
		BorderSizePixel=0, Parent=track,
	})
	Create("UICorner", { CornerRadius=UDim.new(1,0), Parent=knob })
	local dragging = false
	knob.InputBegan:Connect(function(i) if i.UserInputType==Enum.UserInputType.MouseButton1 then dragging=true end end)
	UserInputService.InputEnded:Connect(function(i) if i.UserInputType==Enum.UserInputType.MouseButton1 then dragging=false end end)
	UserInputService.InputChanged:Connect(function(i)
		if dragging and i.UserInputType==Enum.UserInputType.MouseMovement then
			local r = math.clamp((i.Position.X-track.AbsolutePosition.X)/track.AbsoluteSize.X,0,1)
			val = math.floor(min+(max-min)*r); State.Sliders[label]=val; vLbl.Text=tostring(val)
			fill.Size=UDim2.new(r,0,1,0); knob.Position=UDim2.new(r,-6,0.5,-6)
			if callback then callback(val) end
		end
	end)
	return c
end

