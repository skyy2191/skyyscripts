local ESPObjects = {}

local function NewSquare()
	local ok, s = pcall(function()
		local sq = Drawing.new("Square"); sq.Visible=false; sq.Thickness=1; sq.Filled=false; sq.Transparency=1; return sq
	end)
	return ok and s or { Visible=false, Position=Vector2.zero, Size=Vector2.zero, Color=Color3.new(1,1,1), Thickness=1, Filled=false, Transparency=1, Remove=function() end }
end
local function NewLine()
	local ok, l = pcall(function()
		local ln = Drawing.new("Line"); ln.Visible=false; ln.Thickness=1; ln.Transparency=1; return ln
	end)
	return ok and l or { Visible=false, From=Vector2.zero, To=Vector2.zero, Color=Color3.new(1,1,1), Thickness=1, Transparency=1, Remove=function() end }
end
local function NewText()
	local ok, t = pcall(function()
		local tx = Drawing.new("Text"); tx.Visible=false; tx.Size=13; tx.Center=true; tx.Outline=true
		tx.OutlineColor=Color3.fromRGB(0,0,0); tx.Transparency=1
