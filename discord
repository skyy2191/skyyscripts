local function SwitchTab(name)
	for n,p in pairs(TabPages) do p.Visible=n==name end
	for n,b in pairs(TabButtons) do
		b.TextColor3=n==name and Color3.new(1,1,1) or CONFIG.SubText
		b.BackgroundColor3=n==name and CONFIG.AccentColor or Color3.fromRGB(0, 0, 0)
		Tween(b, { BackgroundTransparency = n==name and 0.8 or 0 }, 0.2)
	end
end
for i, tabName in ipairs(tabs) do
	local btn = Create("TextButton", {
		Text=tabName, Font=Enum.Font.GothamBold, TextSize=11,
		TextColor3=i==1 and Color3.new(1,1,1) or CONFIG.SubText,
		BackgroundTransparency=i==1 and 0.8 or 0,
		BackgroundColor3=i==1 and CONFIG.AccentColor or Color3.fromRGB(0, 0, 0),
		Size=UDim2.new(0,80,0,26), Parent=TabBar, AutoButtonColor=false,
	})
	Create("UICorner", { CornerRadius=UDim.new(0,6), Parent=btn })
	Create("UIStroke", { Color=Color3.fromRGB(60, 0, 100), Thickness=1, Parent=btn })
	local page = Create("Frame", { Size=UDim2.new(1,0,1,0), BackgroundTransparency=1, Visible=i==1, Parent=ContentArea })
	TabButtons[tabName]=btn; TabPages[tabName]=page
	btn.MouseButton1Click:Connect(function() SwitchTab(tabName) end)
end

local function MakeSplitPane(tabName, leftTitle, rightTitle)
	local page = TabPages[tabName]
	local function Panel(xPos, title)
		local f = Create("Frame", {
			Size=UDim2.new(0.5,-6,0.99,0), Position=UDim2.new(xPos,xPos>0 and 4 or 2,0,0),
			BackgroundColor3=Color3.fromRGB(3, 0, 6),
			BorderSizePixel=0, Parent=page,
		})
		Create("UICorner", { CornerRadius=UDim.new(0,3), Parent=f })
		Create("UIStroke", { Color=Color3.fromRGB(50, 0, 80), Thickness=1, Parent=f })
		local hdr = Create("Frame", { Size=UDim2.new(0.5,0,0,34), BackgroundTransparency=1, BorderSizePixel=0, Parent=f })
		Create("TextLabel", {
			Text=title, Font=Enum.Font.GothamBold, TextSize=12,
			TextColor3=CONFIG.AccentColor, BackgroundTransparency=1,
			Position=UDim2.new(0,14,0,0), Size=UDim2.new(1,0,1,0),
			TextXAlignment=Enum.TextXAlignment.Left, Parent=hdr,
		})
		local area = Create("Frame", { Size=UDim2.new(1,0,1,-34), Position=UDim2.new(0,0,0,34), BackgroundTransparency=1, Parent=f })
		return MakeScrollPane(area)
	end
	return Panel(0,leftTitle), Panel(0.5,rightTitle)
end

