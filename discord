local function GetSilentAimTarget()
	local center = Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y / 2)
	local best, bestDist = nil, math.huge

	for _, plr in ipairs(Players:GetPlayers()) do
		if plr == LocalPlayer then continue end
		local c   = plr.Character
		local hum = c and c:FindFirstChildOfClass("Humanoid")
		if not c or not hum or hum.Health <= 0 then continue end

		if SilentAimConfig.CheckWhitelist and ESPWhitelist[plr.UserId] then continue end
		if SilentAimConfig.CheckTeam     and IsSameTeam(plr) then continue end

		local partPos = GetPartPosition(c, SilentAimConfig.HitPart)
		if not partPos then continue end

		if SilentAimConfig.CheckWall and not IsVisible(partPos) then continue end

		local sp, onScreen = Camera:WorldToViewportPoint(partPos)
		if not onScreen or sp.Z < 0 then continue end

		local d = (Vector2.new(sp.X, sp.Y) - center).Magnitude
		if d < SilentAimConfig.FOV and d < bestDist then
			bestDist = d
			best     = { plr = plr, worldPos = partPos }
		end
	end
	return best
end

local ValidSilentTargetParts = {"Head", "Torso", "HumanoidRootPart", "Left Arm", "Right Arm", "Left Leg", "Right Leg", "UpperTorso", "LowerTorso"}

local saConnection = nil

local function SetSilentAim(v)
	SilentAimConfig.Enabled = v
	if saConnection then saConnection:Disconnect(); saConnection = nil end
	if not v then return end

	task.spawn(function()
		local ok, err = pcall(function()

	local Events2  = ReplicatedStorage:FindFirstChild("Events2")
	local Visualize = Events2 and Events2:FindFirstChild("Visualize")
	local Events    = ReplicatedStorage:FindFirstChild("Events")
	local DamageEvent = Events and Events:FindFirstChild("ZFKLF__H")

	if not Visualize or not DamageEvent then return end

	saConnection = Visualize.Event:Connect(function(_, ShotCode, _, Gun, _, StartPos, BulletsPerShot)
		if not SilentAimConfig.Enabled then return end

		local tool = LocalPlayer.Character and LocalPlayer.Character:FindFirstChildOfClass("Tool")
		if not tool or Gun ~= tool then return end

		if math.random(1, 100) > SilentAimConfig.HitChance then return end

		local target = GetSilentAimTarget()
		if not target then return end

		local char = target.plr.Character
		if not char then return end
		if char:FindFirstChildOfClass("ForceField") then return end

		local HitPart
		if SilentAimConfig.HitPart == "Any Part" then
			local minDist = math.huge
			local mousePos = UserInputService:GetMouseLocation()
			for _, partName in ipairs(ValidSilentTargetParts) do
				local part = char:FindFirstChild(partName)
				if part then
					local screenPos, onScreen = Camera:WorldToViewportPoint(part.Position)
					if onScreen then
						local dist = (Vector2.new(mousePos.X, mousePos.Y) - Vector2.new(screenPos.X, screenPos.Y)).Magnitude
						if dist < minDist then
							minDist = dist
							HitPart = part
						end
					end
				end
			end
			if not HitPart then HitPart = char:FindFirstChild("Head") end
		else
			HitPart = char:FindFirstChild(SilentAimConfig.HitPart) or char:FindFirstChild("Head")
		end

		if not HitPart then return end

		if HeadshotSoundConfig.Enabled and (HitPart.Name:lower():find("head")) then
			pcall(function()
				local sound = Instance.new("Sound")
				sound.SoundId = HeadshotSounds[HeadshotSoundConfig.Sound]
				sound.Volume = HeadshotSoundConfig.Volume
				sound.Parent = workspace
				sound:Play()
				game.Debris:AddItem(sound, 3)
			end)
		end

		local HitPos = HitPart.Position
		local count = 1
		if type(BulletsPerShot)=="table" then count=#BulletsPerShot elseif type(BulletsPerShot)=="number" then count=BulletsPerShot end
		count = math.clamp(count, 1, 20)
		local lookVector = CFrame.new(StartPos, HitPos).LookVector

		task.wait(0)

		for i=1,count do
			DamageEvent:FireServer("🧈", Gun, ShotCode, i, HitPart, HitPos, lookVector)
		end
		if Gun:FindFirstChild("Hitmarker") then Gun.Hitmarker:Fire(HitPart) end
	end)
end

