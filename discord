local function MakeColorPicker(parent, label, default, callback)
	local currentColor = default or Color3.fromRGB(255, 255, 255)
	local pickerOpen   = false

	local PRESETS = {
		{ name="White",  color=Color3.fromRGB(255,255,255) },
		{ name="Red",    color=Color3.fromRGB(255,50,50)   },
		{ name="Green",  color=Color3.fromRGB(50,255,100)  },
		{ name="Blue",   color=Color3.fromRGB(50,150,255)  },
		{ name="Yellow", color=Color3.fromRGB(255,220,40)  },
		{ name="Orange", color=Color3.fromRGB(255,140,0)   },
		{ name="Purple", color=Color3.fromRGB(180,60,255)  },
		{ name="Cyan",   color=Color3.fromRGB(0,220,255)   },
		{ name="Pink",   color=Color3.fromRGB(255,100,180) },
	}

	local ROWS   = 3
	local COLS   = 3
	local SWATCH = 24
	local GAP    = 4
	local panelH = ROWS * (SWATCH + GAP) + 8
	local panelW = COLS * (SWATCH + GAP) + 8
	local closedH = 36

	local c = Create("Frame", {
		Size=UDim2.new(1,-10,0,closedH),
		BackgroundColor3=Color3.fromRGB(0,0,0),
		BorderSizePixel=0, ClipsDescendants=true,
		Parent=parent,
	})
	Create("UICorner", { CornerRadius=UDim.new(0,5), Parent=c })
	Create("UIStroke", { Color=Color3.fromRGB(60,0,100), Thickness=1, Parent=c })

	Create("TextLabel", {
		Text=label, Font=Enum.Font.GothamMedium, TextSize=12,
		TextColor3=CONFIG.TextColor, BackgroundTransparency=1,
		Position=UDim2.new(0,8,0,0), Size=UDim2.new(0.55,0,0,closedH),
		TextXAlignment=Enum.TextXAlignment.Left, Parent=c,
	})

	local preview = Create("TextButton", {
		Text="", BackgroundColor3=currentColor,
		Position=UDim2.new(1,-42,0.5,-11), Size=UDim2.new(0,38,0,22),
		BorderSizePixel=0, Parent=c,
	})
	Create("UICorner", { CornerRadius=UDim.new(0,4), Parent=preview })
	Create("UIStroke", { Color=Color3.fromRGB(100,0,180), Thickness=1, Parent=preview })

	local arrow = Create("TextLabel", {
		Text="▾", Font=Enum.Font.GothamBold, TextSize=12,
		TextColor3=CONFIG.AccentColor, BackgroundTransparency=1,
		Position=UDim2.new(1,-58,0,0), Size=UDim2.new(0,16,0,closedH),
		TextXAlignment=Enum.TextXAlignment.Center, Parent=c,
	})

	local panel = Create("Frame", {
		Position=UDim2.new(0,8,0,closedH+4),
		Size=UDim2.new(0, panelW, 0, panelH),
		BackgroundColor3=Color3.fromRGB(5,0,10),
		BorderSizePixel=0, Parent=c,
	})
	Create("UICorner", { CornerRadius=UDim.new(0,5), Parent=panel })
	Create("UIStroke", { Color=Color3.fromRGB(80,0,130), Thickness=1, Parent=panel })

	for i, preset in ipairs(PRESETS) do
		local row = math.floor((i-1) / COLS)
		local col = (i-1) % COLS
		local sw = Create("TextButton", {
			Text="", BackgroundColor3=preset.color,
			Position=UDim2.new(0, 4 + col*(SWATCH+GAP), 0, 4 + row*(SWATCH+GAP)),
			Size=UDim2.new(0, SWATCH, 0, SWATCH),
			BorderSizePixel=0, Parent=panel,
		})
		Create("UICorner", { CornerRadius=UDim.new(0,4), Parent=sw })
		local stroke = Create("UIStroke", { Color=Color3.fromRGB(80,0,130), Thickness=1, Parent=sw })

		sw.MouseEnter:Connect(function()
			Tween(sw, { Size=UDim2.new(0,SWATCH+2,0,SWATCH+2),
				Position=UDim2.new(0, 4+col*(SWATCH+GAP)-1, 0, 4+row*(SWATCH+GAP)-1) }, 0.08)
		end)
		sw.MouseLeave:Connect(function()
			Tween(sw, { Size=UDim2.new(0,SWATCH,0,SWATCH),
				Position=UDim2.new(0, 4+col*(SWATCH+GAP), 0, 4+row*(SWATCH+GAP)) }, 0.08)
		end)
		sw.MouseButton1Click:Connect(function()
			currentColor = preset.color
			preview.BackgroundColor3 = currentColor
			if callback then callback(currentColor) end
			pickerOpen = false
			arrow.Text = "▾"
			Tween(c, { Size=UDim2.new(1,-10,0,closedH) }, 0.15)
		end)
	end

	local function TogglePicker()
		pickerOpen = not pickerOpen
		arrow.Text = pickerOpen and "▴" or "▾"
		local targetH = pickerOpen and (closedH + 8 + panelH) or closedH
		Tween(c, { Size=UDim2.new(1,-10,0,targetH) }, 0.15)
	end

	preview.MouseButton1Click:Connect(TogglePicker)
	local hitzone = Create("TextButton", {
		Text="", BackgroundTransparency=1,
		Position=UDim2.new(0,0,0,0), Size=UDim2.new(1,-48,0,closedH),
		Parent=c,
	})
	hitzone.MouseButton1Click:Connect(TogglePicker)

	return c
end

